# ENV TEMPLATE — QuantumTutor v3.0
# Copia este archivo a .env y rellena tus credenciales

# --- Runtime Generic ---
ENV=production
API_KEY=replace-with-internal-app-key
SECRET_KEY=replace-with-strong-secret
ALLOWED_HOSTS=quantumtutor.cl,api.quantumtutor.cl,admin.quantumtutor.cl

# --- Wolfram Alpha ---
WOLFRAM_APP_ID=TU_CLIENT_ID_DE_WOLFRAM

# --- Pinecone (RAG en la Nube) ---
PINECONE_API_KEY=TU_API_KEY_DE_PINECONE
PINECONE_ENV=us-east-1
VECTOR_STORE=pinecone-serverless

# --- Google OAuth 2.0 (Autenticación Real) ---
GOOGLE_CLIENT_ID=Opcional_Para_Produccion
GOOGLE_CLIENT_SECRET=Opcional_Para_Produccion

# --- Auth Bootstrap (recomendado en despliegues nuevos) ---
# Si el archivo users.json está vacío, estas variables crean el admin inicial.
QT_BOOTSTRAP_ADMIN_EMAIL=admin@tu-dominio.edu
QT_BOOTSTRAP_ADMIN_PASSWORD=cambia-esta-clave
QT_BOOTSTRAP_ADMIN_DISPLAY_NAME=Administrador del Sistema
# Solo para dev local y pruebas heredadas. Mantener en false en entornos reales.
QT_ALLOW_INSECURE_DEFAULT_ADMIN=false

# --- LLM Core (Gemini) ---
# Recomendado: multiples claves separadas por coma para rotacion y cooldown automatico.
GEMINI_API_KEYS=TU_API_KEY_1,TU_API_KEY_2
# Compatibilidad: si solo tienes una clave, tambien puedes usar:
# GEMINI_API_KEY=TU_API_KEY_DE_GOOGLE_AI_STUDIO

# --- LLM Config ---
# Si despliegas en Streamlit Cloud, usa los Secrets de Streamlit.
# Para local, puedes usar modelos de OpenAI/Anthropic si el orquestador se actualiza.
MODEL_NAME=text-embedding-3-large
SIMILARITY_THRESHOLD=0.75

# --- API Surface ---
# Lista separada por comas. Usa * solo si aceptas desactivar credenciales CORS.
QUANTUM_TUTOR_CORS_ORIGINS=https://quantumtutor.cl,https://admin.quantumtutor.cl

# --- Gateway / Trusted Proxy ---
# Habilitar solo cuando la app corre detras de Nginx / Cloudflare u otro proxy confiable.
QT_TRUST_PROXY_HEADERS=true
QT_TRUSTED_PROXY_RANGES=127.0.0.1,::1
QT_ALLOW_PROXY_USER_ID=false
QT_ALLOW_DIRECT_USER_ID=false
QT_ADMIN_HOSTNAMES=admin.quantumtutor.cl
QT_ALLOW_ADMIN_REVIEW_ANY_HOST=false
QT_PROVIDER_BREAKER_NAME=gemini_text
