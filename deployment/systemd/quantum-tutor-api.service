[Unit]
Description=Quantum Tutor FastAPI API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=quantum
Group=www-data
WorkingDirectory=/opt/quantum_tutor/current
EnvironmentFile=/etc/quantum-tutor/quantum_tutor.env
Environment=HOME=/opt/quantum_tutor/current/outputs/state/runtime_home
Environment=HF_HOME=/opt/quantum_tutor/current/outputs/cache/hf
Environment=TORCH_HOME=/opt/quantum_tutor/current/outputs/cache/torch
ExecStartPre=/usr/bin/mkdir -p /opt/quantum_tutor/current/outputs/state/runtime_home /opt/quantum_tutor/current/outputs/cache/hf /opt/quantum_tutor/current/outputs/cache/torch
ExecStart=/opt/quantum_tutor/venv/bin/python -m uvicorn api_quantum_tutor:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/opt/quantum_tutor/current/outputs
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
